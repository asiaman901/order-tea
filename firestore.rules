rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email == 'go.asiaman@gmail.com' && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    function isVerified() {
      return request.auth.token.email_verified == true;
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidProduct(data) {
      return data.keys().hasAll(['category', 'name', 'priceL', 'isActive', 'createdAt', 'updatedAt']) &&
             data.category is string && data.category.size() <= 100 &&
             data.name is string && data.name.size() <= 100 &&
             data.priceL is number &&
             data.isActive is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             (!('englishName' in data) || (data.englishName is string && data.englishName.size() <= 100)) &&
             (!('priceBottle' in data) || data.priceBottle is number) &&
             (!('isHotOption' in data) || data.isHotOption is bool) &&
             (!('isRecommended' in data) || data.isRecommended is bool) &&
             (!('isNew' in data) || data.isNew is bool) &&
             (!('hasFixSugar' in data) || data.hasFixSugar is bool);
    }

    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if resource.data.isActive == true || isAdmin();
      allow create: if isValidId(productId) && isAdmin() && isValidProduct(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time && incoming().keys().size() <= 12;
      allow update: if isValidId(productId) && isAdmin() && isValidProduct(incoming()) && incoming().updatedAt == request.time && incoming().createdAt == existing().createdAt;
      allow delete: if isValidId(productId) && isAdmin();
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'status', 'totalPrice', 'items', 'createdAt', 'updatedAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.status is string && data.status.size() <= 20 &&
             data.totalPrice is number &&
             data.items is list && data.items.size() <= 50 && (data.items.size() == 0 || data.items[0] is map) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             (!('customerName' in data) || (data.customerName is string && data.customerName.size() <= 100)) &&
             (!('customerPhone' in data) || (data.customerPhone is string && data.customerPhone.size() <= 20));
    }

    match /orders/{orderId} {
      allow get: if isValidId(orderId);
      allow list: if isAdmin();
      allow create: if isValidId(orderId) && isValidOrder(incoming()) && 
                    incoming().createdAt == request.time && 
                    incoming().updatedAt == request.time && 
                    incoming().status == 'pending';
      allow update: if isValidId(orderId) && isValidOrder(incoming()) && 
                    incoming().userId == existing().userId && 
                    incoming().createdAt == existing().createdAt && 
                    incoming().updatedAt == request.time &&
                    (
                      isAdmin() || 
                      (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status == 'cancelled' && existing().status == 'pending')
                    );
      allow delete: if false;
    }

    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt is timestamp;
    }

    match /admins/{adminId} {
      allow get: if isValidId(adminId) && isAdmin();
      allow list: if isAdmin();
      allow create: if isValidId(adminId) && isAdmin() && isValidAdmin(incoming()) && incoming().createdAt == request.time;
      allow update: if false;
      allow delete: if isValidId(adminId) && isAdmin();
    }
  }
}
